{
  "id": "vite-react-tailwind",
  "name": "Vite + React + Tailwind",
  "framework": "react",
  "language": "typescript",
  "ui": ["tailwind"],
  "version": "1.0.0",
  "recommendedFor": [
    "single-page-app",
    "landing-page",
    "prototype",
    "dashboard",
    "chrome-extension"
  ],
  "requiredFiles": [
    "package.json",
    "tsconfig.json",
    "vite.config.ts",
    "tailwind.config.ts",
    "postcss.config.js",
    "index.html",
    "src/main.tsx",
    "src/App.tsx",
    "src/index.css"
  ],
  "recommendedDependencies": {
    "dependencies": {
      "react": "^18.3.0",
      "react-dom": "^18.3.0",
      "tailwindcss": "^3.4.0",
      "framer-motion": "^11.0.0",
      "react-router-dom": "^6.0.0"
    },
    "devDependencies": {
      "typescript": "^5.0.0",
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0",
      "@vitejs/plugin-react": "^4.0.0",
      "vite": "^5.0.0",
      "postcss": "^8.0.0",
      "autoprefixer": "^10.0.0"
    }
  },
  "cssStrategy": "tailwind-utilities-with-css-variables",
  "componentStrategy": "custom-components",
  "buildCommand": "vite build",
  "devCommand": "vite dev",
  "port": 5173
}
