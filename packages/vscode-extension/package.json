{
  "name": "claude-skill-router-extension",
  "displayName": "Claude Skill Router",
  "version": "1.0.0",
  "publisher": "claude-skill-router",
  "private": true,
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.93.0"
  },
  "activationEvents": [
    "onCommand:claude-skill-router.scanWorkspace",
    "onCommand:claude-skill-router.recommendSkills",
    "onCommand:claude-skill-router.applyRecommendedPack",
    "onCommand:claude-skill-router.openLatestReport",
    "onCommand:claude-skill-router.runPolicyAudit",
    "onCommand:claude-skill-router.prepareFromPrompt",
    "onCommand:claude-skill-router.installAutopilotSkill",
    "onCommand:claude-skill-router.listExternalSkills",
    "onCommand:claude-skill-router.recommendExternalSkills",
    "onCommand:claude-skill-router.generateImageBrief",
    "onCommand:claude-skill-router.generateCopyVariants",
    "onCommand:claude-skill-router.generateCROSEOPlan",
    "onCommand:claude-skill-router.runLovablePipeline",
    "onCommand:claude-skill-router.generateProductMarketingContext",
    "onCommand:claude-skill-router.generateVisualDirections",
    "onCommand:claude-skill-router.selectBrandTemplate",
    "onCommand:claude-skill-router.generateComponentFirstPlan"
  ],
  "contributes": {
    "commands": [
      {
        "command": "claude-skill-router.scanWorkspace",
        "title": "Claude Skill Router: Scan Workspace"
      },
      {
        "command": "claude-skill-router.recommendSkills",
        "title": "Claude Skill Router: Recommend Skills"
      },
      {
        "command": "claude-skill-router.applyRecommendedPack",
        "title": "Claude Skill Router: Apply Recommended Pack"
      },
      {
        "command": "claude-skill-router.openLatestReport",
        "title": "Claude Skill Router: Open Latest Report"
      },
      {
        "command": "claude-skill-router.runPolicyAudit",
        "title": "Claude Skill Router: Run Policy Audit"
      },
      {
        "command": "claude-skill-router.prepareFromPrompt",
        "title": "Claude Skill Router: Prepare Project From Prompt"
      },
      {
        "command": "claude-skill-router.installAutopilotSkill",
        "title": "Claude Skill Router: Install Autopilot Skill"
      },
      {
        "command": "claude-skill-router.listExternalSkills",
        "title": "Claude Skill Router: List External Skills (Marketplace)"
      },
      {
        "command": "claude-skill-router.recommendExternalSkills",
        "title": "Claude Skill Router: Recommend External Skills"
      },
      {
        "command": "claude-skill-router.generateImageBrief",
        "title": "Claude Skill Router: Generate Image Brief/Prompt"
      },
      {
        "command": "claude-skill-router.generateCopyVariants",
        "title": "Claude Skill Router: Generate Copy Variants"
      },
      {
        "command": "claude-skill-router.generateCROSEOPlan",
        "title": "Claude Skill Router: Generate CRO/SEO Audit Plan"
      },
      {
        "command": "claude-skill-router.runLovablePipeline",
        "title": "Claude Skill Router: Run Lovable-Style Design Pipeline"
      },
      {
        "command": "claude-skill-router.generateProductMarketingContext",
        "title": "Claude Skill Router: Generate Product Marketing Context"
      },
      {
        "command": "claude-skill-router.generateVisualDirections",
        "title": "Claude Skill Router: Generate Visual Directions"
      },
      {
        "command": "claude-skill-router.selectBrandTemplate",
        "title": "Claude Skill Router: Select Brand Template"
      },
      {
        "command": "claude-skill-router.generateComponentFirstPlan",
        "title": "Claude Skill Router: Generate Component-First UI Plan"
      }
    ]
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint: ok'",
    "test": "echo 'tests: ok'",
    "package": "vsce package --no-dependencies",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@claude-skill-router/core": "*",
    "zod": "^3.23.0"
  }
}
